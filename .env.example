# Required
DATABASE_URL=

# Email OTP — Resend (tried first) or SMTP via Nodemailer (fallback)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=EcoRise <onboarding@resend.dev>

# SMTP fallback (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=EcoRise <you@example.com>

# Optional — maps / Gemini features
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GEMINI_API_KEY=
# NEXT_PUBLIC_GOOGLE_AI_API_KEY=
